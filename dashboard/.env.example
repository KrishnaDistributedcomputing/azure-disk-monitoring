# Azure Disk Monitoring Dashboard — Environment Variables
# Copy this file to .env.local and fill in values

# Log Analytics Workspace ID (GUID from Azure portal)
# If not set, the dashboard will use mock/demo data
LOG_ANALYTICS_WORKSPACE_ID=

# Azure credentials are picked up automatically via DefaultAzureCredential
# Ensure you're logged in via `az login` or set these for service principal auth:
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
