; Queue Depth Ramp — Progressive QD increase
; Purpose: Observe latency vs IOPS tradeoff as queue depth increases
[global]
ioengine=libaio
direct=1
bs=4K
runtime=60
time_based
group_reporting
size=10G

[qd-1]
rw=randread
iodepth=1

[qd-4]
rw=randread
iodepth=4
startdelay=60

[qd-16]
rw=randread
iodepth=16
startdelay=120

[qd-64]
rw=randread
iodepth=64
startdelay=180

[qd-128]
rw=randread
iodepth=128
startdelay=240
