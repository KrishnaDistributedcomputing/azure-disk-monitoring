# ============================================================================
# Azure Disk Monitoring POC — .gitignore
# ============================================================================

# ----- Node.js / Next.js -----
node_modules/
.next/
out/
.cache/
*.tsbuildinfo
next-env.d.ts

# ----- Environment & secrets -----
.env
.env.local
.env.*.local

# ----- OS files -----
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ----- IDE / Editor -----
.vscode/settings.json
.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ----- Build outputs -----
dist/
build/

# ----- Azure -----
*.tfstate
*.tfstate.backup
.terraform/

# ----- Logs -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- Misc -----
coverage/
.nyc_output/
